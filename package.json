{
  "name": "agentsam-cms-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c wrangler.jsonc",
    "deploy:dry": "wrangler deploy -c wrangler.toml --dry-run",
    "deploy": "wrangler deploy -c wrangler.toml",
    "smoke": "python3 scripts/smoke/smoke_endpoints.py",
    "smoke:api": "python3 scripts/smoke/smoke_api_v1.py",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && wrangler deploy -c wrangler.jsonc --dry-run",
    "preview-build": "npm run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.91.0"
  }
}
