{
  "name": "agentsam-cms-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c wrangler.jsonc",
    "dev:analytics": "cd analytics-app && npm run dev",
    "build:analytics": "bash scripts/build/build_analytics_app.sh",
    "deploy:dry": "npm run build:analytics && wrangler deploy -c wrangler.toml --dry-run",
    "deploy": "npm run build:analytics && wrangler deploy -c wrangler.toml",
    "smoke": "python3 scripts/smoke/smoke_endpoints.py",
    "smoke:api": "python3 scripts/smoke/smoke_api_v1.py",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:analytics && npm run typecheck",
    "preview-build": "npm run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.91.0"
  }
}
